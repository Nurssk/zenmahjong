rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /gameSaves/{saveId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /gameHistory/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /economy/{economyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /tournamentSaves/{dateKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /tournamentHistory/{dateKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /tournamentScores/{scoreId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /dailyChallenges/{date}/results/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
